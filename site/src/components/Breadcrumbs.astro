---
interface Props {
  items: { label: string; href?: string }[];
}

const { items } = Astro.props;
const allItems = [{ label: 'Home', href: '/' }, ...items];
---

<nav aria-label="Breadcrumb" class="text-sm text-slate-500 mb-6">
  <ol class="flex flex-wrap items-center gap-1" itemscope itemtype="https://schema.org/BreadcrumbList">
    {allItems.map((item, index) => (
      <li class="flex items-center" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        {index > 0 && <span class="mx-2 text-slate-400">/</span>}
        {item.href && index < allItems.length - 1 ? (
          <a href={item.href} itemprop="item" class="hover:text-teal transition-colors">
            <span itemprop="name">{item.label}</span>
          </a>
        ) : (
          <span itemprop="name" class="text-slate-700 font-medium">{item.label}</span>
        )}
        <meta itemprop="position" content={String(index + 1)} />
      </li>
    ))}
  </ol>
</nav>
