---
interface Props {
  items: { question: string; answer: string }[];
}

const { items } = Astro.props;
---

<section class="my-12">
  <h2 class="mb-6">Frequently Asked Questions</h2>
  <div class="space-y-3">
    {items.map((item, index) => (
      <details class="group border border-slate-200 rounded-lg" id={`faq-${index}`}>
        <summary class="flex items-center justify-between cursor-pointer py-4 px-5 font-medium text-navy hover:text-teal-dark transition-colors">
          <span>{item.question}</span>
          <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="px-5 pb-4 text-slate-600 leading-relaxed border-t border-slate-100 pt-3">
          <Fragment set:html={item.answer} />
        </div>
      </details>
    ))}
  </div>
</section>
