---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import LeadFormModal from '../components/LeadFormModal.astro';

interface Props {
  title: string;
  description: string;
  breadcrumbs: { label: string; href?: string }[];
  lastUpdated: string;
  jsonLd?: object | object[];
}

const { title, description, breadcrumbs, lastUpdated, jsonLd } = Astro.props;
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12" itemscope itemtype="https://schema.org/Article">
    <Breadcrumbs items={breadcrumbs} />
    <meta itemprop="dateModified" content={lastUpdated} />
    <meta itemprop="author" content="LMS Guide Editorial Team" />
    <slot />
    <LeadFormModal ctaTitle="Not sure which platform fits?" ctaDescription="Tell us about your business and goals — we will send you a personalized LMS recommendation report with the platforms that actually fit your situation." ctaButtonText="Get My Free Recommendation" />
    <div class="mt-8 pt-6 border-t border-slate-200 text-sm text-slate-500">
      <p>Last updated: <time datetime={lastUpdated}>{new Date(lastUpdated).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time></p>
      <p class="mt-1">By the LMS Guide editorial team</p>
    </div>
  </article>
</BaseLayout>
