import KeyTakeaways from '../../components/KeyTakeaways.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import FAQ from '../../components/FAQ.astro';
import LeadFormModal from '../../components/LeadFormModal.astro';
import RelatedPages from '../../components/RelatedPages.astro';

const faqItems = [
  {
    question: "Is Moodle really free?",
    answer: "The Moodle LMS software itself is free and open-source under the GPL license. However, running Moodle involves costs: self-hosted deployments require server infrastructure, setup, and ongoing maintenance (typically $80–$500+/month for hosting plus setup costs). MoodleCloud offers hosted plans starting at $170/year for 50 users. For large organizations, Moodle Workplace requires licensing through certified partners. The 'free' label applies to the software license, not the total cost of ownership."
  },
  {
    question: "What is the difference between Moodle LMS, MoodleCloud, and Moodle Workplace?",
    answer: "Moodle LMS is the free, open-source software you download and host yourself. MoodleCloud is a hosted SaaS version with fixed plans (50–750 users) for those who want managed hosting without technical setup. Moodle Workplace is the licensed enterprise version sold through partners, adding multi-tenancy, advanced compliance tracking, HRIS integrations, and dedicated support. Choose LMS if you have IT resources and want maximum control; Cloud for simple, small-scale needs; Workplace for large enterprise deployments."
  },
  {
    question: "How does Moodle compare to Thinkific?",
    answer: "Moodle and Thinkific serve fundamentally different audiences. Moodle is an open-source academic/corporate LMS with deep customization, advanced assessment tools, and enterprise scale — ideal for institutions and large organizations with technical resources. Thinkific is a proprietary learning commerce platform built for solo experts and small businesses to sell courses quickly with minimal technical overhead. Moodle wins on flexibility and academic features; Thinkific wins on ease of use and built-in commerce. See our <a href='/compare/thinkific-vs-moodle' class='text-teal-dark hover:underline'>full Moodle vs Thinkific comparison</a> for details."
  },
  {
    question: "Is Moodle good for selling online courses?",
    answer: "Moodle can sell courses, but it is not optimized for e-commerce out of the box. Self-hosted Moodle requires plugins for payment processing; MoodleCloud offers basic Stripe integration on Medium and Standard plans. Moodle lacks native marketing tools, landing page builders, affiliate programs, and advanced sales analytics found in dedicated learning commerce platforms. If selling courses is your primary goal and you lack technical resources, platforms like Thinkific or LearnWorlds will get you to market faster."
  },
  {
    question: "How hard is it to set up Moodle?",
    answer: "Moodle setup complexity depends on your chosen tier. MoodleCloud is the easiest — sign up and start building within minutes, though you're limited to 750 users max. Self-hosted Moodle requires significant technical expertise: Linux server administration, MySQL/PostgreSQL database setup, PHP configuration, SSL certificates, security hardening, and ongoing maintenance. Most organizations need a Moodle-certified partner for initial implementation ($2,000–$25,000+). Plan for weeks to months for a full enterprise deployment with custom theming and integrations."
  },
  {
    question: "Is Moodle suitable for customer training?",
    answer: "Moodle Workplace is designed for corporate training including customer education, with multi-tenancy for separate client portals, automated enrollment rules, and compliance tracking. However, Moodle's dated user interface and lack of native marketing/sales features may create friction for customer-facing academies. For B2B customer training with strict compliance needs, Moodle Workplace works well. For B2C customer education prioritizing modern UX and easy content purchasing, dedicated customer education platforms may be a better fit."
  }
];

