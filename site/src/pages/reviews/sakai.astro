---
import ReviewLayout from '../../layouts/ReviewLayout.astro';
import KeyTakeaways from '../../components/KeyTakeaways.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import FAQ from '../../components/FAQ.astro';
import LeadFormModal from '../../components/LeadFormModal.astro';
import RelatedPages from '../../components/RelatedPages.astro';

const faqItems = [
  {
    question: "Is Sakai still used?",
    answer: "Yes, though Sakai's market share has declined significantly. It remains in use at several major universities including Duke, NYU, and the University of Michigan. However, most institutions have migrated to Canvas, Blackboard Ultra, or Moodle. Sakai's development continues through community contributions, but adoption has slowed considerably."
  },
  {
    question: "Who develops Sakai?",
    answer: "Sakai is developed by the Apereo Foundation, a non-profit organization supporting open-source software for education. Development is community-driven, with contributions from educational institutions rather than a single company. This structure means no vendor lock-in but also no dedicated commercial support team."
  },
  {
    question: "Is Sakai free?",
    answer: "Yes, Sakai is free and open-source under the Educational Community License. Institutions pay only for hosting, support, and customization. Many universities self-host on existing infrastructure. Commercial support is available from third-party providers for organizations lacking internal technical resources."
  },
  {
    question: "What is the difference between Sakai and Canvas?",
    answer: "Both serve higher education, but Canvas has eclipsed Sakai in adoption. Canvas offers a more modern interface, native mobile apps, stronger commercial support from Instructure, and a larger ecosystem. Sakai provides more direct institutional control and customization but requires more technical expertise to deploy and maintain."
  },
  {
    question: "Is Sakai suitable for K-12 schools?",
    answer: "Sakai is designed specifically for higher education workflows and would be poorly suited for K-12 use. The interface, terminology, and features assume university structures: multiple terms, complex enrollment, research collaboration, and academic freedom. K-12 schools should consider Canvas, Google Classroom, or Schoology instead."
  },
  {
    question: "Should new institutions choose Sakai?",
    answer: "Probably not. While Sakai remains functional, declining adoption means fewer resources, smaller community support, and limited future innovation. New implementations are rare. Most institutions evaluating open-source options choose Moodle or Canvas Open Source for their larger communities and continued growth."
  }
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Review",
    "itemReviewed": {
      "@type": "SoftwareApplication",
      "name": "Sakai",
      "applicationCategory": "Learning Management System",
      "operatingSystem": "Web"
    },
    "reviewRating": {
      "@type": "Rating",
      "ratingValue": "3.3",
      "bestRating": "5",
      "worstRating": "1"
    },
    "author": {
      "@type": "Organization",
      "name": "LMS Guide"
    },
    "publisher": {
      "@type": "Organization",
      "name": "LMS Guide"
    },
    "datePublished": "2026-03-25",
    "dateModified": "2026-03-25",
    "description": "An honest review of Sakai LMS for higher education. Current state, remaining users, limitations, and whether it's still a viable choice."
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer.replace(/<[^>]*>/g, '')
      }
    }))
  }
];
---

<ReviewLayout
  title="Sakai Review 2026: Open-Source LMS for Higher Education"
  description="An honest review of Sakai LMS for higher education. Current state, remaining users, limitations, and whether it's still a viable choice."
  platformName="Sakai"
  rating={3.3}
  breadcrumbs={[{ label: 'Reviews', href: '/reviews' }, { label: 'Sakai' }]}
  lastUpdated="2026-03-25"
  jsonLd={jsonLd}
>

  <h1 class="text-3xl md:text-4xl font-bold text-navy mb-4">Sakai Review 2026: Open-Source LMS for Higher Education</h1>

  <!-- Rating Display -->
  <div class="flex items-center gap-3 mb-6">
    <div class="flex items-center gap-1" aria-label="Rating: 3.3 out of 5 stars">
      <!-- Star 1 (filled) -->
