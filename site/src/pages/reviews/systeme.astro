<ReviewLayout
  title="Systeme.io Review 2026: Budget All-in-One for Course Creators"
  description="An honest, in-depth review of Systeme.io for course creators on a budget. All-in-one features, limitations, and who it's best for."
  platformName="Systeme.io"
  rating={3.6}
  breadcrumbs={[{ label: 'Reviews', href: '/reviews' }, { label: 'Systeme.io' }]}
  lastUpdated="2026-03-25"
  jsonLd={jsonLd}
>

  <h1 class="text-3xl md:text-4xl font-bold text-navy mb-4">Systeme.io Review 2026: Budget All-in-One for Course Creators</h1>

  <!-- Rating Display -->
  <div class="flex items-center gap-3 mb-6">
    <div class="flex items-center gap-1" aria-label="Rating: 3.6 out of 5 stars">
      <!-- Star 1 (filled) -->
