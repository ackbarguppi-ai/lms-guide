import FAQ from '../../components/FAQ.astro';
import LeadFormModal from '../../components/LeadFormModal.astro';
import RelatedPages from '../../components/RelatedPages.astro';

const faqItems = [
  {
    question: "Is Systeme.io a legitimate LMS?",
    answer: "Systeme.io is more accurately described as an all-in-one marketing platform with course delivery capabilities rather than a dedicated LMS. It provides essential learning features (course hosting, student management, progress tracking) but lacks advanced LMS functionality like SCORM support, sophisticated assessments, and learning path automation. For experts prioritizing marketing and sales over complex learning features, it's sufficient. For organizations needing enterprise learning management, it falls short."
  },
  {
    question: "How much does Systeme.io cost?",
    answer: "Systeme.io is aggressively priced. The Free plan supports 2,000 contacts, 1 course, and unlimited students. Startup ($27/month) adds 5,000 contacts and 3 courses. Webinar ($47/month) adds 10,000 contacts and webinar functionality. Enterprise ($97/month) supports 15,000+ contacts and unlimited features. This pricing undercuts most competitors significantly, making it attractive for budget-conscious creators."
  },
  {
    question: "What does 'all-in-one' mean for Systeme.io?",
    answer: "Systeme.io combines email marketing, course hosting, sales funnels, blog hosting, affiliate management, and automation in a single platform. The value proposition is eliminating the need for separate tools like Mailchimp, Teachable, ClickFunnels, and WordPress. However, the trade-off is that each individual feature is less sophisticated than dedicated point solutions."
  },
  {
    question: "Is Systeme.io good for beginners?",
    answer: "Yes, Systeme.io is designed for beginners with a simple interface, minimal technical requirements, and an affordable free tier. The learning curve is gentler than specialized course platforms or marketing tool stacks. However, creators outgrow Systeme.io as their business scales—advanced automation, custom integrations, and sophisticated course features eventually require migrating to more capable platforms."
  },
  {
    question: "How does Systeme.io compare to Thinkific?",
    answer: "Systeme.io is an all-in-one marketing platform with basic course features. Thinkific is a dedicated course platform with advanced learning features and optional marketing add-ons. Systeme.io wins on price and marketing tool integration; Thinkific wins on course delivery sophistication, student experience, and learning features. Serious course creators typically outgrow Systeme.io while growing into Thinkific. See our <a href='/compare/systeme-vs-thinkific' class='text-teal-dark hover:underline'>full Systeme.io vs Thinkific comparison</a>."
  },
  {
    question: "Does Systeme.io have transaction fees?",
    answer: "No, Systeme.io does not charge transaction fees on any plan. This is a significant advantage over some competitors that take a percentage of sales. However, standard payment processor fees (Stripe: 2.9% + 30¢; PayPal: variable) still apply. The lack of platform transaction fees makes Systeme.io particularly attractive for high-volume sellers on a budget."
  }
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Review",
    "itemReviewed": {
      "@type": "SoftwareApplication",
      "name": "Systeme.io",
      "applicationCategory": "Learning Management System",
      "operatingSystem": "Web"
    },
    "reviewRating": {
      "@type": "Rating",
      "ratingValue": "3.6",
      "bestRating": "5",
      "worstRating": "1"
    },
    "author": {
      "@type": "Organization",
      "name": "LMS Guide"
    },
    "publisher": {
      "@type": "Organization",
      "name": "LMS Guide"
    },
    "datePublished": "2026-03-25",
    "dateModified": "2026-03-25",
    "description": "An honest, in-depth review of Systeme.io for course creators on a budget. All-in-one features, limitations, and who it's best for."
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer.replace(/<[^>]*>/g, '')
      }
    }))
  }
];
