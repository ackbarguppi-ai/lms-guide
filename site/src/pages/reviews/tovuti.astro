import LeadFormModal from '../../components/LeadFormModal.astro';
import RelatedPages from '../../components/RelatedPages.astro';

const faqItems = [
  {
    question: "What is Tovuti LMS?",
    answer: "Tovuti is a cloud-based Learning Management System with built-in course authoring capabilities. Unlike platforms that require separate authoring tools, Tovuti includes a comprehensive content creation suite with 40+ interactive content types, allowing organizations to build courses directly within the platform. It's designed for businesses that want an all-in-one solution without purchasing additional software."
  },
  {
    question: "How much does Tovuti LMS cost?",
    answer: "Tovuti uses quote-based pricing with tiered plans based on active user count. Pricing typically starts around $700-$1,000 per month for smaller implementations and scales up based on features and user volume. The platform charges per active user rather than total registered users, which can be cost-effective for organizations with intermittent training needs. Contact Tovuti directly for exact pricing based on your requirements."
  },
  {
    question: "Does Tovuti have built-in course authoring?",
    answer: "Yes—this is Tovuti's standout feature. The platform includes a comprehensive authoring tool with 40+ interactive content types including interactive video, branching scenarios, quizzes, games, flashcards, and more. You can build fully interactive courses without purchasing separate authoring software like Articulate or Adobe Captivate. Content is SCORM-compliant and can be exported if needed."
  },
  {
    question: "What types of content can I create in Tovuti?",
    answer: "Tovuti supports over 40 content types including: interactive video with clickable hotspots, branching scenarios, drag-and-drop activities, memory games, flashcards, image carousels, timelines, checklists, assessments with 10+ question types, surveys, PDF embeds, and more. The platform also supports SCORM, xAPI, and AICC imports for content created in external tools."
  },
  {
    question: "Is Tovuti good for customer training?",
    answer: "Yes. Tovuti offers strong features for external training including white-labeling, custom domains, eCommerce with Stripe and PayPal integration, subscription billing, and bundled course offerings. The built-in authoring makes it easy to create product training, onboarding sequences, and certification programs. However, it lacks some of the advanced CRM integrations found in dedicated customer education platforms."
  },
  {
    question: "How does Tovuti compare to Thinkific?",
    answer: "Tovuti and Thinkific serve different markets. Tovuti is an enterprise LMS with built-in authoring, designed for organizations that need to create and manage training programs internally. Thinkific is a learning commerce platform optimized for selling courses to external learners. Tovuti excels at internal training and complex content creation; Thinkific excels at marketing, sales, and delivering a polished student experience. See our <a href='/compare/thinkific-vs-tovuti' class='text-teal-dark hover:underline'>full Thinkific vs Tovuti comparison</a>."
  }
];

