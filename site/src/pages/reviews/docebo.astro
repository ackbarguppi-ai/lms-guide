---
import ReviewLayout from '../../layouts/ReviewLayout.astro';
import KeyTakeaways from '../../components/KeyTakeaways.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import FAQ from '../../components/FAQ.astro';
import LeadFormModal from '../../components/LeadFormModal.astro';
import RelatedPages from '../../components/RelatedPages.astro';

const faqItems = [
  {
    question: "Is Docebo an LMS?",
    answer: "Yes, but Docebo positions itself as more than a traditional LMS. It combines LMS functionality with LXP (Learning Experience Platform) features, AI-powered content creation, skills intelligence, and extended enterprise capabilities. The platform is designed for organizations that need to train multiple audiences—employees, customers, and partners—from a single instance."
  },
  {
    question: "How much does Docebo cost?",
    answer: "Docebo uses quote-based pricing, but their Elevate tier starts around $9 per user per month with a 250-user minimum (approximately $2,250/month). The Enterprise tier includes more integrations and dedicated support. Many features—Communities, eCommerce, Advanced Analytics, AI Virtual Coaching, branded mobile apps—are paid add-ons, so the total cost depends on which capabilities you need."
  },
  {
    question: "What is Harmony AI in Docebo?",
    answer: "Harmony is Docebo's embedded AI layer that acts as a copilot for both learners and administrators. It includes semantic search (learners ask questions in natural language), contextual admin guidance, and AI-powered content creation through Docebo Creator. Harmony also powers AI Virtual Coaching, which provides immersive role-play simulations for sales enablement and leadership development."
  },
  {
    question: "Is Docebo good for customer education?",
    answer: "Yes. Customer education is one of Docebo's strongest use cases. The platform offers dedicated customer training solutions with white-labeled academies, CRM integrations, and analytics that connect learning to business outcomes like product adoption and retention. Docebo cites measurable results: customers see up to 3x conversion rates, 30% faster onboarding, and 10% reduction in churn."
  },
  {
    question: "How does Docebo compare to Thinkific?",
    answer: "Docebo and Thinkific serve different markets. Docebo is an enterprise platform for organizations training 250+ learners across multiple audiences, with deep compliance certifications and AI features. Thinkific targets online educators and smaller businesses with transparent pricing and faster setup. For mid-market customer education programs, both can work—Docebo offers more enterprise features, while Thinkific provides simpler implementation and lower cost. See our <a href='/compare/thinkific-vs-docebo' class='text-teal-dark hover:underline'>full Thinkific vs Docebo comparison</a>."
  },
  {
    question: "Does Docebo offer a free trial?",
    answer: "Docebo does not offer a self-serve free trial. Their sales process involves consultation and demo requests. This reflects their enterprise focus—they want to understand your use case and configure the platform appropriately rather than letting users explore independently. For organizations evaluating multiple platforms, this means budgeting time for sales calls and demonstrations."
  }
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Review",
    "itemReviewed": {
      "@type": "SoftwareApplication",
      "name": "Docebo",
      "applicationCategory": "Learning Management System",
      "operatingSystem": "Web"
    },
    "reviewRating": {
      "@type": "Rating",
      "ratingValue": "4.3",
      "bestRating": "5",
      "worstRating": "1"
    },
    "author": {
      "@type": "Organization",
      "name": "LMS Guide"
    },
    "publisher": {
      "@type": "Organization",
      "name": "LMS Guide"
    },
    "datePublished": "2026-03-22",
    "dateModified": "2026-03-22",
    "description": "An honest, in-depth review of Docebo for enterprise learning, customer education, and multi-audience training. Who it's best for, key strengths, limitations, and pricing."
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer.replace(/<[^>]*>/g, '')
      }
    }))
  }
];
---

<ReviewLayout
  title="Docebo Review 2026: Enterprise LMS for Multi-Audience Training"
  description="An honest, in-depth review of Docebo for enterprise learning, customer education, and multi-audience training. Who it's best for, key strengths, limitations, and pricing."
  platformName="Docebo"
  rating={4.3}
  breadcrumbs={[{ label: 'Reviews', href: '/reviews' }, { label: 'Docebo' }]}
  lastUpdated="2026-03-22"
  jsonLd={jsonLd}
>

  <h1 class="text-3xl md:text-4xl font-bold text-navy mb-4">Docebo Review 2026: Enterprise LMS for Multi-Audience Training</h1>

  <!-- Rating Display -->
  <div class="flex items-center gap-3 mb-6">
    <div class="flex items-center gap-1" aria-label="Rating: 4.3 out of 5 stars">
      <!-- Star 1 (filled) -->
      <svg class="w-6 h-6 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
      <!-- Star 2 (filled) -->
      <svg class="w-6 h-6 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
      <!-- Star 3 (filled) -->
      <svg class="w-6 h-6 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
      <!-- Star 4 (filled) -->
      <svg class="w-6 h-6 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
      <!-- Star 5 (partial - ~30% filled for 4.3 rating) -->
      <svg class="w-6 h-6 text-slate-300" viewBox="0 0 20 20">
        <defs>
          <linearGradient id="partial-star-docebo">
            <stop offset="30%" stop-color="#fbbf24" />
            <stop offset="30%" stop-color="#cbd5e1" />
          </linearGradient>
        </defs>
        <path fill="url(#partial-star-docebo)" d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
    </div>
    <span class="text-lg font-semibold text-navy">4.3 / 5</span>
  </div>

  <!-- Summary Verdict -->
  <div class="bg-slate-50 border border-slate-200 rounded-lg p-6 mb-8">
    <p class="text-slate-700 leading-relaxed">
      <strong>The bottom line:</strong> Docebo is a powerful enterprise learning platform that excels at training multiple audiences—employees, customers, and partners—from a single system. With deep AI features, strong security certifications, and proven scale (30M+ learners worldwide), it is a credible choice for mid-market to enterprise organizations. The trade-offs are complexity, opaque pricing, and a 250-user minimum that excludes smaller operations.
    </p>
  </div>

  <!-- Who this is for -->
  <p class="text-slate-600 mb-8 leading-relaxed">
    This review is written for enterprise learning leaders, L&D directors, customer education managers, and IT decision-makers evaluating Docebo against other LMS and learning platform options. If you are trying to consolidate learning tools, scale training across multiple audiences, or need enterprise-grade security and compliance, this is for you.
  </p>

  <!-- Key Takeaways -->
  <KeyTakeaways items={[
    "Docebo is built for enterprise multi-audience training—employees, customers, and partners—through a single platform instance with distinct branded experiences.",
    "AI capabilities are a genuine differentiator, including Harmony AI copilot, AI Virtual Coaching for role-play simulations, and AI-powered content creation through Docebo Creator.",
    "Security and compliance certifications are industry-leading: ISO 27001/27701, SOC 2, FedRAMP Moderate, GDPR, CCPA, and EU AI Act compliance.",
    "Customer education is a core strength with dedicated solutions, CRM integrations, and proven ROI metrics including churn reduction and upsell increases.",
    "The 250-user minimum and quote-based pricing model exclude small businesses and solopreneurs. This is an enterprise platform, not a expert tool.",
    "Many capabilities—Communities, eCommerce, Advanced Analytics, AI Virtual Coaching—are paid add-ons, so total cost of ownership can exceed base pricing significantly."
  ]} />

  <!-- What is Docebo? -->
  <section class="mb-10">
    <h2 class="text-2xl font-bold text-navy mb-4">What is Docebo?</h2>
    <p class="text-slate-700 leading-relaxed mb-4">
      Docebo (pronounced "doh-CHAY-bo," Latin for "I will teach") is a publicly traded enterprise learning platform headquartered in Toronto. It positions itself as "the only AI workforce readiness platform that brings together skills, learning, and outcomes." With 30M+ learners worldwide and Fortune 500 customers including Zoom, Target, Booking.com, and GE Appliances, Docebo operates at significant scale.
    </p>
    <p class="text-slate-700 leading-relaxed mb-4">
      Docebo has deliberately moved beyond the traditional LMS label. The platform combines LMS functionality with LXP (Learning Experience Platform) features, AI-powered content creation, skills intelligence (via its 365Talents acquisition), and extended enterprise capabilities. This means organizations can train employees, customers, and partners from one system while maintaining distinct branding, content catalogs, and admin rights for each audience.
    </p>
    <p class="text-slate-700 leading-relaxed">
      The platform is cloud-native with unlimited storage, supports 50+ languages with AI-powered instant translation, and offers native mobile apps. Docebo's focus on AI is substantial—Harmony AI provides semantic search, content creation, virtual coaching simulations, and administrative copilot capabilities that go well beyond basic LMS functionality.
    </p>
  </section>

  <!-- Who is Docebo Best For? -->
  <section class="mb-10">
    <h2 class="text-2xl font-bold text-navy mb-4">Who is Docebo Best For?</h2>
    <p class="text-slate-700 leading-relaxed mb-6">
      Docebo is not a universal solution. The 250-user minimum and enterprise feature set make it inappropriate for smaller operations. Here is where it fits best:
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-4">
      <div class="bg-white border border-slate-200 rounded-lg p-5">
        <h3 class="font-semibold text-navy mb-2">Mid-Market to Enterprise Organizations</h3>
        <p class="text-slate-600 text-sm leading-relaxed">
          Companies with 250+ learners that need a scalable, secure learning platform. Docebo is proven at massive scale—Zoom trains 2M+ learners on the platform—and offers the compliance certifications enterprise IT requires.
        </p>
      </div>

      <div class="bg-white border border-slate-200 rounded-lg p-5">
        <h3 class="font-semibold text-navy mb-2">Multi-Audience Training Programs</h3>
        <p class="text-slate-600 text-sm leading-relaxed">
          Organizations that need to train employees, customers, and partners from one platform instance. Docebo's Extended Enterprise add-on enables distinct branded portals with separate content catalogs and admin rights for each audience.
        </p>
      </div>

      <div class="bg-white border border-slate-200 rounded-lg p-5">
        <h3 class="font-semibold text-navy mb-2">Customer Education Teams</h3>
        <p class="text-slate-600 text-sm leading-relaxed">
          SaaS companies and product businesses where customer training drives adoption, retention, and upsell. Docebo cites measurable results: 3x conversion rates, 30% faster onboarding, and 10% churn reduction for trained customers.
        </p>
      </div>

      <div class="bg-white border border-slate-200 rounded-lg p-5">
        <h3 class="font-semibold text-navy mb-2">Regulated Industries</h3>
        <p class="text-slate-600 text-sm leading-relaxed">
          Financial services, healthcare, pharma, and government organizations that require strict compliance. Docebo holds ISO 27001/27701, SOC 2, FedRAMP Moderate, GDPR, and EU AI Act certifications—credentials few competitors match.
        </p>
      </div>
    </div>
  </section>

  <!-- Core Capabilities -->
  <section class="mb-10">
    <h2 class="text-2xl font-bold text-navy mb-4">Core Capabilities</h2>

    <h3 class="text-lg font-semibold text-navy mt-6 mb-3">Learning Management</h3>
    <p class="text-slate-700 leading-relaxed mb-4">
      Docebo's core LMS supports blended learning (online, instructor-led, webinars, virtual classrooms, microlearning), SCORM 1.2/2004, Tin Can/xAPI, and AICC content. Certification and compliance tracking includes automated recertification workflows and audit-ready reporting. White-labeling is extensive—customizable UI, branding, pages, and menus per audience.
    </p>

    <h3 class="text-lg font-semibold text-navy mt-6 mb-3">AI Features (Harmony)</h3>
    <p class="text-slate-700 leading-relaxed mb-4">
      Harmony is Docebo's AI copilot layer. Harmony Search provides semantic, conversational search across courses and knowledge bases. Harmony for Support gives admins contextual guidance with auto-navigation. AI Virtual Coaching offers immersive role-play simulations for sales, customer success, and leadership development with real-time feedback on clarity, confidence, and non-verbal cues. Docebo Creator generates interactive courses, assessments, and videos from documents or text prompts, claiming 70x faster content creation.
    </p>

    <h3 class="text-lg font-semibold text-navy mt-6 mb-3">Extended Enterprise</h3>
    <p class="text-slate-700 leading-relaxed mb-4">
      A paid add-on that enables training multiple external audiences—customers, partners, resellers, dealers, franchises—from a single platform instance. Each audience gets distinct branded sub-domains, admin rights, and content catalogs. Unified reporting across all audiences provides visibility into the entire learning ecosystem.
    </p>

    <h3 class="text-lg font-semibold text-navy mt-6 mb-3">eCommerce</h3>
    <p class="text-slate-700 leading-relaxed mb-4">
      Built-in eCommerce or integrations with Shopify, Stripe, PayPal, Adyen, and others. Supports single courses, subscriptions, bundles, discounts, and memberships. Training Credits (virtual credits) streamline procurement for B2B sales. No transaction fees from Docebo—only third-party gateway fees apply.
    </p>

    <h3 class="text-lg font-semibold text-navy mt-6 mb-3">Content Ecosystem</h3>
    <p class="text-slate-700 leading-relaxed mb-4">
      Three content sources: (1) Docebo Creator for AI-generated courses, (2) a marketplace of 30,000+ professional courses and certifications, and (3) third-party authoring tool support. This flexibility lets organizations blend custom content with off-the-shelf training.
    </p>

    <h3 class="text-lg font-semibold text-navy mt-6 mb-3">Integrations</h3>
    <p class="text-slate-700 leading-relaxed mb-4">
      400+ integrations across CRM (Salesforce, HubSpot), collaboration (Microsoft Teams, Zoom), HRIS (BambooHR, ADP), eCommerce, and analytics. Docebo Connect provides iPaaS capabilities for low-code workflow automation. Deep embeds for Salesforce and Microsoft Teams are available as paid add-ons.
    </p>
  </section>

  <!-- Key Strengths -->
  <section class="mb-10">
    <h2 class="text-2xl font-bold text-navy mb-4">Key Strengths</h2>

    <div class="space-y-5">
      <div>
        <h3 class="font-semibold text-navy mb-1">Multi-Audience Architecture</h3>
        <p class="text-slate-700 leading-relaxed">
          Training employees, customers, and partners from one platform with distinct branded experiences is a genuine differentiator. Most LMS platforms are designed for single-audience use cases. Docebo's Extended Enterprise add-on enables complex, multi-tenant learning operations without maintaining separate systems.
        </p>
      </div>

      <div>
        <h3 class="font-semibold text-navy mb-1">AI Feature Depth</h3>
        <p class="text-slate-700 leading-relaxed">
          Harmony AI, AI Virtual Coaching, and AI content creation provide more AI surface area than most competitors. The virtual coaching feature—immersive role-play simulations with real-time feedback—is particularly differentiated and useful for sales enablement and leadership development.
        </p>
      </div>

      <div>
        <h3 class="font-semibold text-navy mb-1">Enterprise Security Posture</h3>
        <p class="text-slate-700 leading-relaxed">
          ISO 27001/27017/27018/27701, SOC 2, FedRAMP Moderate, GDPR, CCPA, EU AI Act, and DORA compliance. This certification stack makes Docebo suitable for regulated industries where security and compliance are non-negotiable.
        </p>
      </div>

      <div>
        <h3 class="font-semibold text-navy mb-1">Proven Scale</h3>
        <p class="text-slate-700 leading-relaxed">
          30M+ learners worldwide. Zoom trains 2M+ learners on Docebo. Unlimited cloud storage and 50+ language support with AI translation enable global deployments without technical constraints.
        </p>
      </div>

      <div>
        <h3 class="font-semibold text-navy mb-1">Analytics Sophistication</h3>
        <p class="text-slate-700 leading-relaxed">
          600+ data tables, Snowflake-powered data warehouse, BI tool integration, and Kirkpatrick-based evaluation frameworks. The Advanced Analytics add-on provides correlation capabilities that connect learning data to business outcomes.
        </p>
      </div>

      <div>
        <h3 class="font-semibold text-navy mb-1">Customer Education Specialization</h3>
        <p class="text-slate-700 leading-relaxed">
          Dedicated solutions with proven ROI metrics. Docebo understands that customer training is a revenue driver, not a cost center, and builds features accordingly—including CRM integrations that tie learning to customer health scores.
        </p>
      </div>
    </div>
  </section>

  <!-- Where Docebo May Not Be the Best Fit -->
  <section class="mb-10">
    <h2 class="text-2xl font-bold text-navy mb-4">Where Docebo May Not Be the Best Fit</h2>
    <p class="text-slate-700 leading-relaxed mb-4">
      Honest evaluation requires acknowledging limitations. Here is where Docebo falls short:
    </p>

    <div class="space-y-5">
      <div>
        <h3 class="font-semibold text-navy mb-1">Small Businesses and Solopreneurs</h3>
        <p class="text-slate-700 leading-relaxed">
          The 250-user minimum and approximately $2,250/month starting price (before add-ons) puts Docebo out of reach for smaller operations. Individual online educators, coaches, and businesses with fewer than 250 learners should look elsewhere.
        </p>
      </div>

      <div>
        <h3 class="font-semibold text-navy mb-1">Opaque Pricing and Long Contracts</h3>
        <p class="text-slate-700 leading-relaxed">
          Quote-based pricing creates friction in the evaluation process. Most customers sign 3–5 year contracts, creating high switching costs and significant commitment. Organizations wanting pricing transparency or month-to-month flexibility will find Docebo's sales motion frustrating.
        </p>
      </div>

      <div>
        <h3 class="font-semibold text-navy mb-1">Add-On Complexity</h3>
        <p class="text-slate-700 leading-relaxed">
          Communities, eCommerce, Advanced Analytics, AI Virtual Coaching, branded mobile apps, Extended Enterprise, Salesforce and Teams integrations—all are paid add-ons. The "real" platform experience requires significant additional investment beyond base pricing. Budget accordingly.
        </p>
      </div>

      <div>
        <h3 class="font-semibold text-navy mb-1">Implementation Overhead</h3>
        <p class="text-slate-700 leading-relaxed">
          Docebo's 10-step onboarding process and enterprise implementation requirements mean slower time-to-value compared to simpler platforms. Mid-market buyers may find this heavier than necessary for their needs.
        </p>
      </div>

      <div>
        <h3 class="font-semibold text-navy mb-1">Content Lock-In</h3>
        <p class="text-slate-700 leading-relaxed">
          Docebo Creator exports content in xAPI format only. SCORM and PDF export are "planned for future." This creates portability risk—content created in Docebo may be difficult to migrate to other platforms.
        </p>
      </div>
    </div>
  </section>

  <!-- Pricing Overview -->
  <section class="mb-10">
    <h2 class="text-2xl font-bold text-navy mb-4">Pricing Overview</h2>
    <p class="text-slate-700 leading-relaxed mb-4">
      Docebo uses quote-based pricing with two main tiers. The Elevate tier starts around $9 per user per month with a 250-user minimum. Enterprise adds more integrations, dedicated support, and named account management. Many features require paid add-ons.
    </p>

    <div class="overflow-x-auto rounded-lg border border-slate-200 mb-4">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-navy text-white">
            <th class="text-left py-3 px-4 font-semibold">Plan</th>
            <th class="text-left py-3 px-4 font-semibold">Best For</th>
          </tr>
        </thead>
        <tbody>
          <tr class="bg-white border-t border-slate-200">
            <td class="py-3 px-4 font-medium text-navy">Elevate</td>
            <td class="py-3 px-4 text-slate-600">Mid-market organizations with 250+ learners needing core LMS, AI features, and up to 4 integrations</td>
          </tr>
          <tr class="bg-slate-50 border-t border-slate-200">
            <td class="py-3 px-4 font-medium text-navy">Enterprise</td>
            <td class="py-3 px-4 text-slate-600">Large organizations requiring 6+ integrations, dedicated support team, and named account management</td>
          </tr>
        </tbody>
      </table>
    </div>

    <p class="text-slate-700 leading-relaxed mb-4">
      <strong>Common Paid Add-Ons:</strong> Advanced Analytics, AI Virtual Coaching (usage-based credits), Branded Mobile App, Extended Enterprise, Communities, eCommerce, Docebo for Salesforce, Docebo for Microsoft Teams, Content Marketplace, and Immersive Learning (VR/AR).
    </p>

    <p class="text-sm text-slate-500">
      Pricing is quote-based. Contact Docebo for current pricing specific to your user count and required features.
    </p>
  </section>

  <!-- How Docebo Compares -->
  <section class="mb-10">
    <h2 class="text-2xl font-bold text-navy mb-4">How Docebo Compares</h2>
    <p class="text-slate-700 leading-relaxed mb-4">
      Here is how Docebo stacks up against other platforms in the enterprise and learning commerce space:
    </p>

    <ComparisonTable
      headers={["Docebo", "Thinkific", "Absorb", "LearnWorlds", "LearnDash"]}
      highlight={0}
      rows={[
        { feature: "Primary Focus", values: ["Enterprise multi-audience training", "Learning commerce & customer education", "Enterprise internal & external training", "Learning commerce & site building", "WordPress-based course delivery"] },
        { feature: "Best For", values: ["Mid-large enterprise, 250+ users", "Academies, learning businesses", "Corporate training programs", "Branded learning sites", "WordPress-native users"] },
        { feature: "AI Features", values: ["Harmony AI, virtual coaching", "Thinker AI assistant", "AI features available", "AI tools available", "Limited"] },
        { feature: "Multi-Audience", values: ["Native (Extended Enterprise)", "Primarily customer/student", "Available", "Limited", "Via plugins"] },
        { feature: "Security", values: ["ISO 27001, SOC 2, FedRAMP", "Standard", "SOC 2, GDPR", "Standard", "Self-hosted dependent"] },
        { feature: "Pricing Model", values: ["Quote-based, $9/user min", "Published tiers, free plan", "Quote-based", "Published tiers", "Plugin + hosting costs"] },
        { feature: "User Minimum", values: ["250 users", "None", "Varies", "None", "None"] },
        { feature: "Ease of Setup", values: ["Implementation required", "Fast, self-serve", "Implementation required", "Fast, managed hosting", "Requires WordPress setup"] }
      ]}
    />
  </section>

  <!-- CTA -->
  <LeadFormModal
    variant="inline"
    ctaTitle="Evaluating whether this platform fits your needs?"
    ctaDescription="Get a personalized recommendation based on your specific use case, team size, and priorities."
    ctaButtonText="Get My Recommendation"
  />

