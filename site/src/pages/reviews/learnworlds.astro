import LeadFormModal from '../../components/LeadFormModal.astro';
import RelatedPages from '../../components/RelatedPages.astro';

const faqItems = [
  {
    question: "Is LearnWorlds an LMS?",
    answer: "Yes, LearnWorlds is a cloud-based LMS, but it positions itself more broadly as an all-in-one learning commerce platform. It combines course creation, website building, mobile app development, and e-commerce in a single platform. Unlike traditional corporate LMS platforms focused on internal compliance training, LearnWorlds is built primarily for selling and delivering learning experiences to external audiences."
  },
  {
    question: "What is LearnWorlds' interactive video feature?",
    answer: "Interactive video is LearnWorlds' standout differentiator. It allows experts to add auto-extracted transcripts, in-video quizzes, tables of contents, clickable buttons, pointers, and watermarks directly within video content. AI can generate interactive elements from uploaded video, and learners can engage with content without leaving the video player. Most competitors do not offer this depth of video interactivity."
  },
  {
    question: "How much does LearnWorlds cost?",
    answer: "LearnWorlds offers four tiers: Starter ($29/month, but with a $5 per enrollment fee), Pro Trainer ($99/month), Learning Center ($299/month), and High Volume & Corporate (custom pricing). The Starter plan has significant limitations — no free courses and the per-enrollment fee makes it expensive at scale. Most serious users start at Pro Trainer or Learning Center. Annual billing saves approximately 20%."
  },
  {
    question: "Can I build a mobile app with LearnWorlds?",
    answer: "Yes. LearnWorlds offers a white-label native mobile app builder for iOS and Android on higher-tier plans. The visual editor requires no coding and supports in-app purchases, push notifications, and 100% custom branding. This is a genuine differentiator — few competitors offer this level of mobile app customization without hiring developers."
  },
  {
    question: "Does LearnWorlds have AI features?",
    answer: "LearnWorlds brands itself as the '#1 AI-powered LMS' and includes AI tools across all plans. Features include AI course planning, ebook writing, assessment generation, AI-powered feedback, interactive video elements, copy assistance, content translation, and natural language analytics (AI Insights). However, the AI is primarily content-generation focused — there is no adaptive learning AI or AI tutoring chatbot for learners."
  },
  {
    question: "How does LearnWorlds compare to Thinkific?",
    answer: "Both platforms compete in the learning commerce space, but LearnWorlds emphasizes interactive video and AI features more heavily, while Thinkific offers stronger community features and a free plan. LearnWorlds wins on video interactivity and AI breadth; Thinkific wins on entry-level pricing (free plan available), API accessibility on lower tiers, and proprietary SOC 2 certification. See our <a href='/compare/thinkific-vs-learnworlds' class='text-teal-dark hover:underline'>full Thinkific vs LearnWorlds comparison</a> for detailed analysis."
  }
];

