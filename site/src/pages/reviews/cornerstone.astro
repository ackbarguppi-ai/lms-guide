import LeadFormModal from '../../components/LeadFormModal.astro';
import RelatedPages from '../../components/RelatedPages.astro';

const faqItems = [
  {
    question: "What is Cornerstone OnDemand?",
    answer: "Cornerstone OnDemand is an enterprise talent management and learning platform that combines LMS, learning experience platform (LXP), skills intelligence, performance management, and HR capabilities in a unified suite. Following its acquisition of Saba Software in 2020 and subsequent take-private by Clearlake Capital in 2022, Cornerstone serves 7,000+ organizations and 125M+ users globally. It's one of the largest and most established players in the enterprise learning and talent management space."
  },
  {
    question: "How much does Cornerstone cost?",
    answer: "Cornerstone uses custom, quote-based pricing that varies by modules selected, user count, and deployment scope. There are no published prices. Enterprise contracts typically start in the $50,000–$100,000+ annual range for mid-market organizations, with large enterprise deployments reaching several hundred thousand dollars annually. Implementation costs are additional. Expect a consultative sales process with multiple demos and proposals."
  },
  {
    question: "Is Cornerstone better than SAP SuccessFactors for learning?",
    answer: "Cornerstone generally offers deeper learning-specific functionality than SAP SuccessFactors Learning. Cornerstone's LXP, content marketplace, skills intelligence, and compliance features are more mature. However, organizations already invested in the SAP ecosystem may prefer SuccessFactors for tighter HR integration. The choice often depends on whether learning or broader HCM integration is the higher priority."
  },
  {
    question: "What happened to Saba after Cornerstone acquired it?",
    answer: "Cornerstone acquired Saba Software in April 2020 for $1.4 billion. Saba's technology was gradually integrated into Cornerstone's platform, with key capabilities like virtual classroom management and social learning absorbed into the core product. Existing Saba customers were migrated to Cornerstone's platform over a multi-year transition period. See our <a href='/reviews/saba' class='text-teal-dark hover:underline'>Saba review</a> for more on the legacy platform and migration path."
  },
  {
    question: "How does Cornerstone compare to Thinkific?",
    answer: "Cornerstone and Thinkific serve entirely different markets. Cornerstone is an enterprise talent management suite for large organizations managing employee learning, compliance, and skills development. Thinkific is a platform for experts and businesses to create and sell online courses with full brand control. There is minimal overlap—Cornerstone is for internal corporate training, Thinkific is for customer education and learning businesses."
  },
  {
    question: "Does Cornerstone offer a content library?",
    answer: "Yes. Cornerstone Content Anytime provides access to a curated library of professional content from providers including Skillsoft, LinkedIn Learning, Coursera for Business, and others. The content marketplace aggregates third-party content alongside internally created materials. Organizations can also use Cornerstone's AI to recommend content based on individual skill gaps and career paths."
  }
];

