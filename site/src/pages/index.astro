---
import BaseLayout from '../layouts/BaseLayout.astro';
import RelatedPages from '../components/RelatedPages.astro';

const title = "LMS Guide";
const description = "Independent, buyer-focused LMS comparisons and reviews. Find the right learning platform for customer training, branded academies, course businesses, and enterprise education.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "LMS Guide",
  "url": "https://lms-guide.com",
  "description": description,
  "publisher": {
    "@type": "Organization",
    "name": "LMS Guide"
  }
};
---

<BaseLayout title={title} description={description} ogType="website" jsonLd={jsonLd}>

  <!-- Hero -->
  <section class="bg-navy text-white py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6">Find the Right LMS for Your Business</h1>
      <p class="text-lg md:text-xl text-slate-300 max-w-3xl mx-auto mb-8 leading-relaxed">
        Independent comparisons, honest reviews, and buyer-focused guides for learning management systems. No vendor spin — just practical analysis to help you make a confident decision.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/guides/what-buyers-compare" class="inline-block bg-teal hover:bg-teal-light text-white font-semibold py-3 px-8 rounded-lg transition-colors">
          Start With the Buyer Framework
        </a>
        <a href="/guides/best-lms-customer-training" class="inline-block border border-slate-400 hover:border-white text-white font-semibold py-3 px-8 rounded-lg transition-colors">
          Best LMS for Customer Training
        </a>
      </div>
    </div>
  </section>

  <!-- What We Cover -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-2xl md:text-3xl font-bold text-navy text-center mb-4">What We Cover</h2>
    <p class="text-slate-600 text-center max-w-2xl mx-auto mb-12">
      LMS Guide focuses on the platforms and decisions that matter most for customer education, branded academies, and learning commerce.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="text-center">
        <div class="w-12 h-12 bg-teal/10 rounded-lg flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
        </div>
        <h3 class="font-semibold text-navy mb-2">Buyer Guides</h3>
        <p class="text-slate-600 text-sm">Frameworks and criteria for evaluating LMS platforms based on what actually matters for your use case.</p>
      </div>

      <div class="text-center">
        <div class="w-12 h-12 bg-teal/10 rounded-lg flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
        </div>
        <h3 class="font-semibold text-navy mb-2">Platform Reviews</h3>
        <p class="text-slate-600 text-sm">In-depth, honest reviews of leading platforms — strengths, limitations, and who each one is actually built for.</p>
      </div>

      <div class="text-center">
        <div class="w-12 h-12 bg-teal/10 rounded-lg flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
        </div>
        <h3 class="font-semibold text-navy mb-2">Head-to-Head Comparisons</h3>
        <p class="text-slate-600 text-sm">Side-by-side platform comparisons with real decision frameworks — not just feature checklists.</p>
      </div>
    </div>
  </section>

  <!-- Featured Content -->
  <section class="bg-slate-50 py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-8">Start Here</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Guide Card -->
        <a href="/guides/what-buyers-compare" class="group bg-white border border-slate-200 rounded-lg p-6 hover:border-teal hover:shadow-md transition-all">
          <span class="text-xs font-semibold text-teal uppercase tracking-wide">Buyer Guide</span>
          <h3 class="font-bold text-navy group-hover:text-teal-dark mt-2 mb-2">What Buyers Actually Compare When Choosing an LMS</h3>
          <p class="text-sm text-slate-500">The 9-pillar evaluation framework real buyers use — from use-case fit to AI capability.</p>
        </a>

        <!-- Category Card -->
        <a href="/guides/best-lms-customer-training" class="group bg-white border border-slate-200 rounded-lg p-6 hover:border-teal hover:shadow-md transition-all">
          <span class="text-xs font-semibold text-teal uppercase tracking-wide">Best LMS</span>
          <h3 class="font-bold text-navy group-hover:text-teal-dark mt-2 mb-2">Best LMS for Customer Training (2026)</h3>
          <p class="text-sm text-slate-500">Thinkific, Docebo, Absorb, LearnWorlds, and Skilljar compared for customer education.</p>
        </a>

        <!-- Review Card -->
        <a href="/reviews/thinkific" class="group bg-white border border-slate-200 rounded-lg p-6 hover:border-teal hover:shadow-md transition-all">
          <span class="text-xs font-semibold text-teal uppercase tracking-wide">Review</span>
          <h3 class="font-bold text-navy group-hover:text-teal-dark mt-2 mb-2">Thinkific Review 2026</h3>
          <p class="text-sm text-slate-500">Learning commerce platform for customer education, branded academies, and course businesses.</p>
        </a>

        <!-- Comparison Card 1 -->
        <a href="/compare/thinkific-vs-learnworlds" class="group bg-white border border-slate-200 rounded-lg p-6 hover:border-teal hover:shadow-md transition-all">
          <span class="text-xs font-semibold text-teal uppercase tracking-wide">Comparison</span>
          <h3 class="font-bold text-navy group-hover:text-teal-dark mt-2 mb-2">Thinkific vs LearnWorlds</h3>
          <p class="text-sm text-slate-500">Two learning commerce platforms compared on community, branding, interactivity, and pricing.</p>
        </a>

        <!-- Comparison Card 2 -->
        <a href="/compare/thinkific-vs-docebo" class="group bg-white border border-slate-200 rounded-lg p-6 hover:border-teal hover:shadow-md transition-all">
          <span class="text-xs font-semibold text-teal uppercase tracking-wide">Comparison</span>
          <h3 class="font-bold text-navy group-hover:text-teal-dark mt-2 mb-2">Thinkific vs Docebo</h3>
          <p class="text-sm text-slate-500">Learning commerce vs enterprise LMS — which model fits your customer education needs?</p>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
    <h2 class="text-2xl md:text-3xl font-bold text-navy mb-4">Not Sure Where to Start?</h2>
    <p class="text-slate-600 max-w-2xl mx-auto mb-8">
      Our buyer framework helps you identify which evaluation criteria matter most for your specific situation — so you can stop comparing every platform on the market and focus on the two or three that actually fit.
    </p>
    <a href="/guides/what-buyers-compare" class="inline-block bg-teal hover:bg-teal-light text-white font-semibold py-3 px-8 rounded-lg transition-colors">
      Read the 9-Pillar Framework
    </a>
  </section>

</BaseLayout>
