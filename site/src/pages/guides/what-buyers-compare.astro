          <th class="text-center py-3 px-4 font-semibold text-navy border-b border-slate-200">Customer Education</th>
          <th class="text-center py-3 px-4 font-semibold text-navy border-b border-slate-200">Enterprise Internal</th>
          <th class="text-center py-3 px-4 font-semibold text-navy border-b border-slate-200">Membership / Community</th>
          <th class="text-center py-3 px-4 font-semibold text-navy border-b border-slate-200">Open / Flexible Stack</th>
        </tr>
      </thead>
