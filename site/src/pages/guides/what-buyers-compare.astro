          <td class="py-2.5 px-4 text-center">Critical</td>
          <td class="py-2.5 px-4 text-center">Critical</td>
          <td class="py-2.5 px-4 text-center">Critical</td>
          <td class="py-2.5 px-4 text-center">Critical</td>
        </tr>
        <tr class="border-b border-slate-100 bg-slate-50/50">
          <td class="py-2.5 px-4 font-medium">Commerce</td>
          <td class="py-2.5 px-4 text-center">Critical</td>
          <td class="py-2.5 px-4 text-center">Low</td>
          <td class="py-2.5 px-4 text-center">Critical</td>
          <td class="py-2.5 px-4 text-center">Medium</td>
        </tr>
        <tr class="border-b border-slate-100">
          <td class="py-2.5 px-4 font-medium">Branding</td>
          <td class="py-2.5 px-4 text-center">High</td>
          <td class="py-2.5 px-4 text-center">Medium</td>
          <td class="py-2.5 px-4 text-center">High</td>
          <td class="py-2.5 px-4 text-center">Critical</td>
        </tr>
