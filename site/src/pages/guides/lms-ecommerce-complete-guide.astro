          <tr class="border-b"><td class="py-2 px-4 font-medium">Podia</td><td class="py-2 px-4">8%</td><td class="py-2 px-4">0%</td><td class="py-2 px-4">0%</td><td class="py-2 px-4">0%</td></tr>
          <tr class="border-b"><td class="py-2 px-4 font-medium">LearnWorlds</td><td class="py-2 px-4">N/A</td><td class="py-2 px-4">$5/sale</td><td class="py-2 px-4">0%</td><td class="py-2 px-4">0%</td></tr>
