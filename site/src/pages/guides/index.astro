const tagColors: Record<string, string> = {
  "Use Case": "text-teal",
  "Buyer Guide": "text-teal",
  "Industry Report": "text-orange-600",
  "Deep Dive": "text-teal",
  "Complete Guide": "text-indigo-600",
  "Tool": "text-purple-600"
};
---

<BaseLayout title={title} description={description} canonical="https://lms-guide.com/guides/" jsonLd={jsonLd}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-navy mb-6">LMS Buyer Guides (2026)</h1>
    <p class="text-lg text-slate-600 leading-relaxed mb-4">
      Independent research to help you evaluate, compare, and choose the right learning management system. Use-case guides, feature deep dives, and practical buyer tools — no vendor spin.
    </p>
  </section>

  <!-- Use Case Guides -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="text-2xl md:text-3xl font-bold text-navy mb-2">Best LMS by Use Case</h2>
    <p class="text-slate-600 mb-8 max-w-3xl">The right platform depends on what you're building. These guides match platform strengths to specific use cases.</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {useCaseGuides.map(guide => (
        <a href={guide.href} class="group bg-white border border-slate-200 rounded-lg p-6 hover:border-teal hover:shadow-md transition-all">
          <span class={`text-xs font-semibold uppercase tracking-wide ${tagColors[guide.tag] || 'text-teal'}`}>{guide.tag}</span>
          <h3 class="font-bold text-navy group-hover:text-teal-dark mt-2 mb-2">{guide.title}</h3>
          <p class="text-sm text-slate-500">{guide.description}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Buyer Guides -->
  <section class="bg-slate-50 py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-2">Buyer Frameworks & Industry Reports</h2>
      <p class="text-slate-600 mb-8 max-w-3xl">Start here to build your evaluation framework before you talk to vendors.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {buyerGuides.map(guide => (
          <a href={guide.href} class="group bg-white border border-slate-200 rounded-lg p-6 hover:border-teal hover:shadow-md transition-all">
            <span class={`text-xs font-semibold uppercase tracking-wide ${tagColors[guide.tag] || 'text-teal'}`}>{guide.tag}</span>
            <h3 class="font-bold text-navy group-hover:text-teal-dark mt-2 mb-2">{guide.title}</h3>
            <p class="text-sm text-slate-500">{guide.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Deep Dive Guides -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-2xl md:text-3xl font-bold text-navy mb-2">Feature Deep Dives</h2>
    <p class="text-slate-600 mb-8 max-w-3xl">Side-by-side feature comparisons across leading platforms — what's actually different and why it matters.</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {deepDiveGuides.map(guide => (
        <a href={guide.href} class="group bg-white border border-slate-200 rounded-lg p-6 hover:border-teal hover:shadow-md transition-all">
          <span class={`text-xs font-semibold uppercase tracking-wide ${tagColors[guide.tag] || 'text-teal'}`}>{guide.tag}</span>
          <h3 class="font-bold text-navy group-hover:text-teal-dark mt-2 mb-2">{guide.title}</h3>
          <p class="text-sm text-slate-500">{guide.description}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Complete Guides -->
  <section class="bg-slate-50 py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-2">Complete Topic Guides</h2>
      <p class="text-slate-600 mb-8 max-w-3xl">Everything you need to know about a specific LMS feature area or topic — from first principles to vendor comparison.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {completeGuides.map(guide => (
          <a href={guide.href} class="group bg-white border border-slate-200 rounded-lg p-6 hover:border-teal hover:shadow-md transition-all">
            <span class={`text-xs font-semibold uppercase tracking-wide ${tagColors[guide.tag] || 'text-teal'}`}>{guide.tag}</span>
            <h3 class="font-bold text-navy group-hover:text-teal-dark mt-2 mb-2">{guide.title}</h3>
            <p class="text-sm text-slate-500">{guide.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Buyer Tools -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-2xl md:text-3xl font-bold text-navy mb-2">Buyer Tools</h2>
    <p class="text-slate-600 mb-8 max-w-3xl">Practical templates and checklists for running a rigorous LMS evaluation.</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {buyerTools.map(tool => (
        <a href={tool.href} class="group bg-white border border-slate-200 rounded-lg p-6 hover:border-teal hover:shadow-md transition-all">
          <span class={`text-xs font-semibold uppercase tracking-wide ${tagColors[tool.tag] || 'text-purple-600'}`}>{tool.tag}</span>
          <h3 class="font-bold text-navy group-hover:text-teal-dark mt-2 mb-2">{tool.title}</h3>
          <p class="text-sm text-slate-500">{tool.description}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <LeadFormModal
      ctaTitle="Not sure where to start?"
      ctaDescription="Tell us about your use case and team size — we'll send you a personalized LMS recommendation based on what you're actually trying to build."
      ctaButtonText="Get My Free Recommendation"
    />
  </section>

</BaseLayout>
