---

<BaseLayout title={title} description={description} canonical="https://lms-guide.com/compare/" jsonLd={jsonLd}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- Hero Section -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-navy mb-6">LMS Platform Comparisons (2026)</h1>
    <p class="text-lg text-slate-600 leading-relaxed mb-4">
      Choosing the right learning platform is a high-stakes decision. These side-by-side comparisons break down 
      the key differences between leading LMS and learning commerce platforms — not just feature checklists, 
      but real decision frameworks based on what buyers actually compare.
    </p>
    <p class="text-slate-600">
      Whether you're building a customer education program, launching a branded academy, or comparing enterprise 
      LMS options, these guides will help you make a confident, informed choice.
    </p>
  </section>

  <!-- Comparison Builder Lead Form -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <ComparisonLeadForm />
  </section>

  <!-- Learning Commerce Comparisons -->
  <section class="bg-slate-50 py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-navy mb-2">Learning Commerce Comparisons</h2>
      <p class="text-slate-600 mb-8 max-w-3xl">
        Comparing platforms built for selling courses, coaching, and digital products — 
        Kajabi, Podia, Teachable, and LearnWorlds head-to-head.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {learningCommerceComparisons.map((comparison) => (
          <a 
            href={comparison.href} 
            class="group bg-white border border-slate-200 rounded-lg p-6 hover:border-teal hover:shadow-md transition-all flex flex-col h-full"
          >
            <h3 class="font-bold text-navy group-hover:text-teal-dark text-lg mb-3">{comparison.title}</h3>
            <p class="text-slate-600 text-sm flex-grow">{comparison.description}</p>
            <span class="text-teal text-sm font-medium mt-4 inline-flex items-center">
              Read comparison
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Enterprise LMS Comparisons -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h2 class="text-2xl md:text-3xl font-bold text-navy mb-2">Enterprise LMS Comparisons</h2>
    <p class="text-slate-600 mb-8 max-w-3xl">
      For organizations needing scalable, compliance-ready learning management — 
      comparing Docebo, Absorb, TalentLMS, and Moodle for enterprise use cases.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {enterpriseLMSComparisons.map((comparison) => (
        <a 
          href={comparison.href} 
          class="group bg-white border border-slate-200 rounded-lg p-6 hover:border-teal hover:shadow-md transition-all flex flex-col h-full"
        >
          <h3 class="font-bold text-navy group-hover:text-teal-dark text-lg mb-3">{comparison.title}</h3>
          <p class="text-slate-600 text-sm flex-grow">{comparison.description}</p>
          <span class="text-teal text-sm font-medium mt-4 inline-flex items-center">
            Read comparison
            <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- CTA Section -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <LeadFormModal
      ctaTitle="Not sure which comparison to start with?"
      ctaDescription="Tell us about your use case — customer training, employee onboarding, or selling courses — and we'll send you a personalized LMS recommendation with the platforms that actually fit your situation."
      ctaButtonText="Get My Free Recommendation"
    />
  </section>
</BaseLayout>
