  { feature: "Commerce / monetization", values: ["Native storefronts, flexible pricing, memberships, bundles, marketing funnels", "Built-in e-commerce (zero commission) but B2B-focused, no marketing tools"] },
  { feature: "Communities / memberships", values: ["Built-in communities, membership tiers, ongoing engagement tools", "Social learning features; limited native community product"] },
