  { feature: "Pricing model", values: ["Per active learner + tier", "Annual subscription + monthly active users"] },
  { feature: "Employee training", values: ["✅ Core strength", "❌ Not designed for it"] },
  { feature: "Customer training", values: ["✅ Supported (eCommerce portal)", "✅ Core strength"] },
  { feature: "AI features", values: ["Deep (Absorb Aura, Intelligence suite)", "Basic (AI Content Assist, LearnExpert add-on)"] },
  { feature: "CRM integration", values: ["Salesforce, generic CRM via API", "Salesforce-native, deep CRM/CS tooling"] },
