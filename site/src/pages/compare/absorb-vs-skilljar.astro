const relatedPages = [
  { title: "Thinkific vs Absorb", href: "/compare/thinkific-vs-absorb", description: "Branded academy platform vs enterprise LMS — different approaches to customer and partner training." },
  { title: "Thinkific vs Skilljar", href: "/compare/thinkific-vs-skilljar", description: "Two customer education platforms compared on integrations, analytics, and enterprise readiness." },
  { title: "Docebo vs Skilljar", href: "/compare/docebo-vs-skilljar", description: "Enterprise LMS vs purpose-built customer education — which fits your training strategy." },
