  { feature: "Starting price", values: ["Custom (~$5.83–$10/user/month)", "$8–$13/user/month (300 user minimum)"] },
  { feature: "Deployment time", values: ["6–12 weeks", "2–4 weeks"] },
  { feature: "Mobile app", values: ["Yes (branded app on Enterprise tier)", "No native app (mobile browser only)"] },
  { feature: "Multi-audience training", values: ["✅ Employees + customers + partners", "Primarily internal employee training"] },
  { feature: "Integrations", values: ["400+ (Salesforce, Teams, SAP, Oracle)", "Growing (Slack, GitHub, SharePoint, Salesforce)"] },
