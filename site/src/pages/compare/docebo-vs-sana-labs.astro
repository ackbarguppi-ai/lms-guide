const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Docebo vs Sana Labs (2026): Enterprise LMS Heavyweights Compared",
    "description": "Docebo is the safer pick for complex, multi-audience enterprise training. Sana Labs is the AI-native challenger — faster to deploy, easier to use, and now backed by Workday. Compare features, pricing, and fit.",
