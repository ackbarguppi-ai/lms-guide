const comparisonRows = [
  { feature: "Best for", values: ["Mid-market to enterprise (500–25,000+ learners)", "SMBs and growing teams (5–1,000 learners)"] },
  { feature: "Starting price", values: ["~$14,000/year (custom quotes)", "Free (5 users); paid from $119/month"] },
  { feature: "Setup time", values: ["Weeks to months", "Hours to days"] },
  { feature: "AI features", values: ["Absorb Intelligence, Aura, Create", "TalentCraft AI, AI Coach, AI translations"] },
  { feature: "Compliance tools", values: ["eSignatures, observational checklists, audit trails", "Basic certificates, recertification tracking"] },
  { feature: "eCommerce", values: ["Built-in eCommerce portal", "Basic eCommerce with Stripe/PayPal"] },
  { feature: "Mobile app", values: ["Native iOS/Android with offline support", "Native iOS/Android app"] },
  { feature: "Gamification", values: ["Points, badges, leaderboards, polls, forums", "Points, badges, levels, team leaderboards"] },
  { feature: "Content library", values: ["Thousands of pre-built courses (Absorb Amplify)", "TalentLibrary (1,000+ CPD-accredited courses)"] },
  { feature: "G2 rating", values: ["4.6/5 (~500 reviews)", "4.6/5 (~750 reviews)"] },
