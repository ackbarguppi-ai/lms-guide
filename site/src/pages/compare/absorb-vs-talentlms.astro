const relatedPages = [
  { title: "TalentLMS vs Docebo", href: "/compare/talentlms-vs-docebo", description: "Affordable cloud LMS vs enterprise AI powerhouse — which fits your scale and budget." },
  { title: "Absorb vs Skilljar", href: "/compare/absorb-vs-skilljar", description: "Corporate training powerhouse vs customer education specialist." },
