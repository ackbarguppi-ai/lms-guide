const relatedPages = [
  { title: "TalentLMS vs Docebo", href: "/compare/talentlms-vs-docebo", description: "Affordable cloud LMS vs enterprise AI powerhouse." },
  { title: "Absorb vs Skilljar", href: "/compare/absorb-vs-skilljar", description: "Corporate training powerhouse vs customer education specialist." },
  { title: "Thinkific vs Skilljar", href: "/compare/thinkific-vs-skilljar", description: "Learning commerce vs customer education platform." },
  { title: "Docebo vs Skilljar", href: "/compare/docebo-vs-skilljar", description: "Enterprise LMS vs purpose-built customer education." },
