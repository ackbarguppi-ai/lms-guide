const comparisonRows = [
  { feature: "Primary use case", values: ["Employee training, compliance, onboarding", "Customer education, partner enablement"] },
  { feature: "Target audience", values: ["HR teams, L&D departments, SMBs", "Customer success teams, SaaS companies"] },
  { feature: "Pricing model", values: ["Transparent tiers ($119–$449+/mo)", "Custom pricing (annual + per-user fees)"] },
  { feature: "AI features", values: ["Extensive (TalentCraft, AI Coach)", "Limited (LearnExperts add-on)"] },
  { feature: "CRM integration", values: ["HubSpot", "Salesforce, HubSpot, Gainsight"] },
  { feature: "Mobile app", values: ["Native iOS/Android", "Responsive web (no native app)"] },
  { feature: "Gamification", values: ["Points, badges, leaderboards", "Certificates, progress tracking"] },
  { feature: "eCommerce", values: ["Basic built-in", "Advanced with multiple currencies"] },
  { feature: "Custom branding", values: ["Good", "Excellent (academy builder)"] },
  { feature: "Compliance tracking", values: ["Strong (audits, certs, recertification)", "Basic (certifications)"] },
];

const faqItems = [
  {
    question: "Is TalentLMS or Skilljar better for customer training?",
    answer: "Skilljar is better. It was purpose-built for customer education with deep CRM integration, branded academy sites, content syndication, and monetization. TalentLMS can train external users but wasn't designed for customer education at scale."
  },
  {
    question: "Can TalentLMS be used for customer education?",
    answer: "Yes, TalentLMS can train external audiences through branches, but it lacks the branded academy experience and CRM integrations that customer success teams need to prove training ROI."
