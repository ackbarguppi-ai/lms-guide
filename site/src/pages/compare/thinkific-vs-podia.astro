      {
        "@type": "Question",
        "name": "Can I use quizzes and assessments on both platforms?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Thinkific offers advanced quizzes with question banks, randomization, multiple question types, pass thresholds, and timed exams. Podia only supports basic multiple-choice quizzes without randomization or detailed analytics."
        }
      },
      {
        "@type": "Question",
        "name": "Which is easier to set up for beginners?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Podia is generally faster to set up with a simpler interface and fewer configuration options. Thinkific has a steeper learning curve but offers more customization and control over the learning experience."
        }
      }
    ]
  }
];

const comparisonRows = [
  { feature: "Platform type", values: ["Robust course platform with learning focus", "All-in-one digital selling platform"] },
  { feature: "Best for", values: ["Structured courses, assessments, branded academies", "Fast setup, multiple product types, simplicity"] },
  { feature: "Course creation", values: ["Advanced: 12+ lesson types, SCORM, prerequisites", "Simple: clean lesson list, basic content types"] },
  { feature: "Quizzes & assessments", values: ["Question banks, randomization, timed exams", "Basic multiple-choice only"] },
  { feature: "Mobile app", values: ["Thinkific Mobile (Start+) + Branded Mobile option", "None — mobile-responsive web only"] },
  { feature: "Email marketing", values: ["Basic native; external integration recommended", "Full built-in suite with automations & segmentation"] },
  { feature: "Transaction fees", values: ["0% on all plans", "5% (Mover) / 0% (Shaker)"] },
  { feature: "AI features", values: ["AI course outline generator, AI quiz generator", "None"] },
  { feature: "Website builder", values: ["Full site builder with HTML/CSS editing (Start+)", "Simple template-based pages, limited customization"] },
  { feature: "Pricing (annual)", values: ["Basic: $36/mo, Start: $74/mo, Grow: $149/mo", "Mover: $33/mo, Shaker: $75/mo"] },
];

const faqItems = [
  {
    question: "Is Thinkific or Podia better for course creators?",
    answer: "Thinkific is better for creators building structured courses with quizzes, certificates, and learning paths. Podia is better for creators who want the fastest path to selling courses alongside other digital products like downloads and memberships."
  },
  {
    question: "Does Podia have a mobile app?",
    answer: "No, Podia does not have a native mobile app for iOS or Android. Students access content through mobile-responsive web pages. Thinkific offers both a branded mobile app (included on Start+) and a fully white-label Branded Mobile option."
  },
  {
    question: "Which platform has better email marketing?",
    answer: "Podia includes a full built-in email suite with broadcasts, automations, and segmentation on all plans. Thinkific offers basic native email but most users integrate external tools like Mailchimp or ConvertKit for full email marketing capabilities."
  },
  {
    question: "How do transaction fees compare?",
    answer: "Thinkific charges 0% transaction fees on all plans. Podia charges 5% on the Mover plan ($39/mo) and 0% on the Shaker plan ($89/mo). At higher revenue levels, Podia's 5% fee makes the Shaker plan or Thinkific more economical."
  },
  {
    question: "Can I use quizzes and assessments on both platforms?",
    answer: "Thinkific offers advanced quizzes with question banks, randomization, multiple question types, pass thresholds, and timed exams. Podia only supports basic multiple-choice quizzes without randomization or detailed analytics."
  },
  {
    question: "Which is easier to set up for beginners?",
