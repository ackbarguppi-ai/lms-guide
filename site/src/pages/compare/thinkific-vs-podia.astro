const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Thinkific vs Podia (2026): Robust Course Platform vs Simple All-in-One",
    "description": "Thinkific offers deeper learning features, advanced assessments, and mobile apps. Podia provides simpler setup with built-in email marketing. Compare features, pricing, and use cases.",
    "author": {
      "@type": "Organization",
      "name": "LMS Guide Editorial Team"
    },
    "publisher": {
      "@type": "Organization",
