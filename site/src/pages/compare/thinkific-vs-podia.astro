      {
        "@type": "Question",
        "name": "Does Podia have a mobile app?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No, Podia does not have a native mobile app for iOS or Android. Students access content through mobile-responsive web pages. Thinkific offers both a branded mobile app (included on Start+) and a fully white-label Branded Mobile option."
        }
      },
      {
        "@type": "Question",
        "name": "Which platform has better email marketing?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Podia includes a full built-in email suite with broadcasts, automations, and segmentation on all plans. Thinkific offers basic native email but most users integrate external tools like Mailchimp or ConvertKit for full email marketing capabilities."
        }
      },
      {
        "@type": "Question",
        "name": "How do transaction fees compare?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Thinkific charges 0% transaction fees on all plans. Podia charges 5% on the Mover plan ($39/mo) and 0% on the Shaker plan ($89/mo). At higher revenue levels, Podia's 5% fee makes the Shaker plan or Thinkific more economical."
        }
